install.packages("ggthemes")
library(scales)
library(ggthemes)
library(tidyverse)
library(ggplot2)
library(RColorBrewer)
library(treemapify)
# Load in necessary data
median_assets_debts <- read_csv("median_assets_debt.csv")
knitr::opts_chunk$set(echo = TRUE)
# Other Races 2022 Assets
other_2022_assets <- median_assets_debts %>%
filter(
year == 2022,
racecl4 %in% c("White", "Hispanic", "Other"),
metric_type == "Asset",
metric %in% c(
"Cash Value of Whole Life Insurance",
"Directly Held Stocks",
"Pooled Investment Fund Assets",
"Quasi-Liquid Retirement Accounts",
"Total Value of Household Stock Holdings"
)
) %>%
group_by(metric) %>%
summarise(median = median(median, na.rm = TRUE)) %>%
mutate(group = "Other Races")
# install.packages(c("readr","dplyr","tidyr","tidygeocoder","leaflet","scales"))
library(readr); library(dplyr); library(tidyr)
library(tidygeocoder); library(leaflet); library(scales)
df <- read_csv("Liquor_Outlet_Density_per_1,000_Residents_-_City.csv", show_col_types = FALSE)
# install.packages(c("readr","dplyr","tidyr","tidygeocoder","leaflet","scales"))
library(readr); library(dplyr); library(tidyr)
library(tidygeocoder); library(leaflet); library(scales)
df <- read_csv("/Users/joyamelvin/Downloads/Liquor_Outlet_Density_per_1,000_Residents_-_City.csv", show_col_types = FALSE)
df_long <- df %>%
pivot_longer(cols = starts_with("liquor"),
names_to = "var",
values_to = "value") %>%
mutate(year = as.integer(paste0("20", stringr::str_extract(var, "\\d{2}$")))) %>%
select(-var)
# pick a year to map
year_to_map <- 2011
map_df <- df_long %>% filter(year == year_to_map)
# geocode city names (this uses Nominatim/free service — rate-limited)
# add state if you have it (better accuracy)
map_df_geo <- map_df %>%
distinct(City) %>%
tidygeocoder::geocode(City, method = 'osm', lat = latitude , long = longitude)
# join coordinates back and keep value
map_df2 <- map_df %>% left_join(map_df_geo, by = "City")
# simple leaflet map with colored circles
pal <- colorNumeric("YlOrRd", domain = map_df2$value, na.color = "transparent")
leaflet(map_df2) %>%
addProviderTiles(providers$CartoDB.Positron) %>%
addCircleMarkers(~longitude, ~latitude,
radius = ~scales::rescale(value, to = c(4, 20), from = range(value, na.rm = TRUE)),
color = ~pal(value),
stroke = FALSE, fillOpacity = 0.8,
label = ~paste0(City, ": ", value)) %>%
addLegend("bottomright", pal = pal, values = ~value, title = paste0("Liquor density ", year_to_map))
