library(scales)
library(ggthemes)
library(tidyverse)
library(ggplot2)
library(RColorBrewer)
library(treemapify)
# Load in necessary data
median_assets_debts <- read_csv("median_assets_debt.csv")
knitr::opts_chunk$set(echo = TRUE)
# ChatGPT helped with a parent node, making area of each metric more relative
first_plot <- ggplot(combined_assets, aes(
area = median,
fill = metric,
subgroup = group,
label = str_c(metric, "\n$", format(round(median, 0), big.mark = ","))
)) +
geom_treemap() +
geom_treemap_subgroup_border(color = "white", size = 4) +
geom_treemap_subgroup_text(
aes(label = group),
color = "black",
fontface = "bold",
place = "bottomright",
alpha = 0.6,
size = 9
) +
geom_treemap_text(color = "white", place = "center", reflow = TRUE) +
labs(
title = "Racial Disparities in Median Asset Values, 2022",
subtitle = "Other Races (White, Hispanic, Other) vs. Black",
caption = "Source: Black Weath Data Center calculations from the 2022 U.S. Federal Reserve, Survey of Consumer Finances (SCF)"
) +
theme_fivethirtyeight() +
scale_fill_brewer(palette = "Set1") +
theme(legend.position = "none",
plot.caption = element_text(size = 8, hjust = 0.5),
plot.title = element_text(size = 14, hjust = 0.5),
plot.subtitle = element_text(size = 10, hjust = 0.5, alpha = 0.6)
)
